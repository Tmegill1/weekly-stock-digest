# Supabase — use service_role key for the ingestion pipeline
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# SEC EDGAR — required by SEC policy (use your real name and email)
EDGAR_USER_AGENT="Your Name your@email.com"

# Anthropic — used by Phase 2 event extraction (Claude Haiku for free-text parsing)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
